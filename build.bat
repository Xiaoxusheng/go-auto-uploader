@echo off
:: 设置控制台为 UTF-8 编码，防止中文注释或输出乱码
chcp 65001 >nul

echo =======================================================
echo          Go 跨平台极致优化编译脚本 (Uploader)
echo =======================================================

:: ---------------------------------------------------------
:: 初始化输出目录
:: 检查并创建 release 文件夹，用于统一存放编译结果
:: ---------------------------------------------------------
if not exist "release" (
    echo [初始化] 创建 release 输出目录...
    mkdir release
)

:: ---------------------------------------------------------
:: 清理缓存
:: 清除 Go 之前的编译缓存，确保本次编译代码绝对干净最新
:: ---------------------------------------------------------
echo [1/3] 正在清理历史构建缓存...
go clean

:: ---------------------------------------------------------
:: 编译 Windows 平台可执行文件
:: 配置 GOOS=windows 和 GOARCH=amd64
:: 优化参数说明:
:: -trimpath: 移除所有包含绝对路径的编译信息，保障构建产物一致性
:: -ldflags="-s -w": -s 剥离符号表，-w 剥离 DWARF 调试信息，极致压缩体积
:: CGO_ENABLED=0: 禁用 CGO，确保生成不依赖系统库的纯静态文件
:: 输出名称: uploader.exe
:: ---------------------------------------------------------
echo [2/3] 正在全速编译 Windows (amd64) 平台...
set GOOS=windows
set GOARCH=amd64
set CGO_ENABLED=0
go build -trimpath -ldflags="-s -w" -o release/uploader.exe .
if %errorlevel% neq 0 (
    echo [错误] Windows 平台编译失败！
    goto :error
)

:: ---------------------------------------------------------
:: 编译 Linux 平台可执行文件
:: 配置 GOOS=linux 和 GOARCH=amd64
:: 此处同样采用最高级别的体积压缩与静态链接策略，方便直接部署至 Linux 服务器
:: 输出名称: uploader
:: ---------------------------------------------------------
echo [3/3] 正在全速编译 Linux (amd64) 平台...
set GOOS=linux
set GOARCH=amd64
set CGO_ENABLED=0
go build -trimpath -ldflags="-s -w" -o release/uploader .
if %errorlevel% neq 0 (
    echo [错误] Linux 平台编译失败！
    goto :error
)

:: ---------------------------------------------------------
:: 编译成功收尾流程
:: 恢复默认环境变量，并提示用户编译产物的存放位置
:: ---------------------------------------------------------
echo =======================================================
echo ✅ 编译大功告成！最高性能产物已输出至 release 目录。
echo =======================================================

:: 恢复环境变量（防止影响当前终端后续的其他操作）
set GOOS=
set GOARCH=
set CGO_ENABLED=

pause
exit /b 0

:: ---------------------------------------------------------
:: 异常处理入口
:: ---------------------------------------------------------
:error
echo =======================================================
echo ❌ 编译过程中断，请检查代码语法或环境配置。
echo =======================================================
set GOOS=
set GOARCH=
set CGO_ENABLED=
pause
exit /b 1